<script>
import { list${BusinessName}, get${BusinessName}, del${BusinessName}, add${BusinessName}, update${BusinessName} } from "@/api/${moduleName}/${businessName}";

export default {
  name: "${BusinessName}",
#if(${dicts} != '')
  dicts: [${dicts}],
#end
  data() {
    return {
      // жЂ«уйЕт▒ѓ
      loading: true,
      // жђЅСИГТЋ░у╗ё
      ids: [],
#if($table.sub)
      // тГљУАежђЅСИГТЋ░ТЇ«
      checked${subClassName}: [],
#end
      // жЮътЇЋСИфудЂуће
      single: true,
      // жЮътцџСИфудЂуће
      multiple: true,
      // ТўЙуц║Тљюу┤бТЮАС╗Х
      showSearch: true,
      // Тђ╗ТЮАТЋ░
      total: 0,
      // ${functionName}УАеТа╝ТЋ░ТЇ«
      ${businessName}List: [],
#if($table.sub)
      // ${subTable.functionName}УАеТа╝ТЋ░ТЇ«
      ${subclassName}List: [],
#end
      // т╝╣тЄ║т▒ѓТаЄжбў
      title: "",
      // Тў»тљдТўЙуц║т╝╣тЄ║т▒ѓ
      open: false,
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      // $commentТЌХжЌ┤УїЃтЏ┤
      daterange${AttrName}: [],
#end
#end
      // ТЪЦУ»бтЈѓТЋ░
      queryParams: {
        pageNum: 1,
        pageSize: 10,
#foreach ($column in $columns)
#if($column.query)
        $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
      },
      // УАетЇЋтЈѓТЋ░
      form: {},
      // УАетЇЋТаАжфї
      rules: {
#foreach ($column in $columns)
#if($column.required)
#set($parentheseIndex=$column.columnComment.indexOf("№╝ѕ"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
        $column.javaField: [
          { required: true, message: "$commentСИЇУЃйСИ║уЕ║", trigger: #if($column.htmlType == "select" || $column.htmlType == "radio")"change"#else"blur"#end }
        ]#if($foreach.count != $columns.size()),#end
#end
#end
      }
    };
  },
  created() {
    this.getList();
  },
  methods: {
    /** ТЪЦУ»б${functionName}тѕЌУАе */
    getList() {
      this.loading = true;
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
      this.queryParams.params = {};
#break
#end
#end
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      if (null != this.daterange${AttrName} && '' != this.daterange${AttrName}) {
        this.queryParams.params["begin${AttrName}"] = this.daterange${AttrName}[0];
        this.queryParams.params["end${AttrName}"] = this.daterange${AttrName}[1];
      }
#end
#end
      list${BusinessName}(this.queryParams).then(response => {
        this.${businessName}List = response.rows;
        this.total = response.total;
        this.loading = false;
      });
    },
    // тЈќТХѕТїЅжњ«
    cancel() {
      this.open = false;
      this.reset();
    },
    // УАетЇЋжЄЇуй«
    reset() {
      this.form = {
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
        $column.javaField: []#if($foreach.count != $columns.size()),#end
#else
        $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
      };
#if($table.sub)
      this.${subclassName}List = [];
#end
      this.resetForm("form");
    },
    /** Тљюу┤бТїЅжњ«ТЊЇСйю */
    handleQuery() {
      this.queryParams.pageNum = 1;
      this.getList();
    },
    /** жЄЇуй«ТїЅжњ«ТЊЇСйю */
    resetQuery() {
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      this.daterange${AttrName} = [];
#end
#end
      this.resetForm("queryForm");
      this.handleQuery();
    },
    // тцџжђЅТАєжђЅСИГТЋ░ТЇ«
    handleSelectionChange(selection) {
      this.ids = selection.map(item => item.${pkColumn.javaField})
      this.single = selection.length!==1
      this.multiple = !selection.length
    },
    /** Тќ░тбъТїЅжњ«ТЊЇСйю */
    handleAdd() {
      this.reset();
      this.open = true;
      this.title = "Ти╗тіа${functionName}";
    },
    /** С┐«Тћ╣ТїЅжњ«ТЊЇСйю */
    handleUpdate(row) {
      this.reset();
      const ${pkColumn.javaField} = row.${pkColumn.javaField} || this.ids
      get${BusinessName}(${pkColumn.javaField}).then(response => {
        this.form = response.data;
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
        this.form.$column.javaField = this.form.${column.javaField}.split(",");
#end
#end
#if($table.sub)
        this.${subclassName}List = response.data.${subclassName}List;
#end
        this.open = true;
        this.title = "С┐«Тћ╣${functionName}";
      });
    },
    /** ТЈљС║цТїЅжњ« */
    submitForm() {
      this.#[[$]]#refs["form"].validate(valid => {
        if (valid) {
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
          this.form.$column.javaField = this.form.${column.javaField}.join(",");
#end
#end
#if($table.sub)
          this.form.${subclassName}List = this.${subclassName}List;
#end
          if (this.form.${pkColumn.javaField} != null) {
            update${BusinessName}(this.form).then(response => {
              this.#[[$modal]]#.msgSuccess("С┐«Тћ╣ТѕљтіЪ");
              this.open = false;
              this.getList();
            });
          } else {
            add${BusinessName}(this.form).then(response => {
              this.#[[$modal]]#.msgSuccess("Тќ░тбъТѕљтіЪ");
              this.open = false;
              this.getList();
            });
          }
        }
      });
    },
    /** тѕажЎцТїЅжњ«ТЊЇСйю */
    handleDelete(row) {
      const ${pkColumn.javaField}s = row.${pkColumn.javaField} || this.ids;
      this.#[[$modal]]#.confirm('Тў»тљдуА«У«цтѕажЎц${functionName}у╝ќтЈиСИ║"' + ${pkColumn.javaField}s + '"уџёТЋ░ТЇ«жА╣№╝Ъ').then(function() {
        return del${BusinessName}(${pkColumn.javaField}s);
      }).then(() => {
        this.getList();
        this.#[[$modal]]#.msgSuccess("тѕажЎцТѕљтіЪ");
      }).catch(() => {});
    },
#if($table.sub)
	/** ${subTable.functionName}т║ЈтЈи */
    row${subClassName}Index({ row, rowIndex }) {
      row.index = rowIndex + 1;
    },
    /** ${subTable.functionName}Ти╗тіаТїЅжњ«ТЊЇСйю */
    handleAdd${subClassName}() {
      let obj = {};
#foreach($column in $subTable.columns)
#if($column.pk || $column.javaField == ${subTableFkclassName})
#elseif($column.list && "" != $javaField)
      obj.$column.javaField = "";
#end
#end
      this.${subclassName}List.push(obj);
    },
    /** ${subTable.functionName}тѕажЎцТїЅжњ«ТЊЇСйю */
    handleDelete${subClassName}() {
      if (this.checked${subClassName}.length == 0) {
        this.#[[$modal]]#.msgError("У»итЁѕжђЅТІЕУдЂтѕажЎцуџё${subTable.functionName}ТЋ░ТЇ«");
      } else {
        const ${subclassName}List = this.${subclassName}List;
        const checked${subClassName} = this.checked${subClassName};
        this.${subclassName}List = ${subclassName}List.filter(function(item) {
          return checked${subClassName}.indexOf(item.index) == -1
        });
      }
    },
    /** тцЇжђЅТАєжђЅСИГТЋ░ТЇ« */
    handle${subClassName}SelectionChange(selection) {
      this.checked${subClassName} = selection.map(item => item.index)
    },
#end
    /** т»╝тЄ║ТїЅжњ«ТЊЇСйю */
    handleExport() {
      this.download('${moduleName}/${businessName}/export', {
        ...this.queryParams
      }, `${businessName}_#[[${new Date().getTime()}]]#.xlsx`)
    }
  }
};
</script>
